# ───────────────────────────────────────────────────────────────────────────
# Layguel360 environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. Never commit real keys. Vercel: set the same vars per
# environment (Production / Preview / Development).
# ───────────────────────────────────────────────────────────────────────────

# Supabase ─ public, exposed to the browser
# Project URL and anon key — safe to expose; gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase ─ server-only, NEVER expose to the client
# Service-role key bypasses RLS. Used exclusively from `lib/supabase/admin.ts`
# (which is marked `import 'server-only'`). If a build error mentions this
# var leaking to a client bundle, audit imports of admin.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NVIDIA NIM (optional)
# Powers the `@ai-sdk/openai-compatible` provider configured in opencode.json.
# Only required if AI features ship; safe to omit during Phase 1-4.
NVIDIA_API_KEY=

# Sentry (optional, Phase 7)
# SENTRY_DSN=
